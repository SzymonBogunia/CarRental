@page
@model CarsListModel
@{
    ViewData["Title"] = "Lista Samochodów";
}

<div class="d-flex justify-content-between align-items-center my-4">
    <div>
        <h1 class="fw-bold text-dark">Flota Samochodów</h1>
        <p class="text-muted">Przeglądaj i zarządzaj dostępnymi pojazdami w systemie.</p>
    </div>
    <a asp-page="/CarCreate" class="btn btn-success shadow-sm fw-bold">+ Dodaj nowy samochód</a>
</div>

<div class="row row-cols-1 row-cols-md-3 g-4">
    @if (Model.Cars.Count == 0)
    {
        <div class="col-12 text-center my-5">
            <div class="alert alert-warning py-4" role="alert">
                <h4 class="alert-heading fw-bold">Brak pojazdów!</h4>
                <p class="mb-0">Baza danych SQLite jest pusta. Dodaj samochody przez formularz.</p>
            </div>
        </div>
    }
    else
    {
        @foreach (var car in Model.Cars)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0">
                    @if (!string.IsNullOrEmpty(car.ImageUrl))
                    {
                        <img src="@car.ImageUrl" class="card-img-top" alt="@car.Brand @car.Model" style="height: 200px; object-fit: cover;">
                    }
                    else
                    {
                        <img src="/images/cars/default.jpg" class="card-img-top" alt="Brak zdjęcia" style="height: 200px; object-fit: cover;">
                    }
                    <div class="card-header bg-dark text-white fw-bold">
                        @car.Brand
                    </div>
                    <div class="card-body">
                        <h5 class="card-title fw-bold text-primary mb-3">@car.Model</h5>
                        <p class="card-text mb-2"><strong>Rok produkcji:</strong> @car.ProductionYear</p>
                        <p class="card-text mb-3"><strong>Rejestracja:</strong> <span class="badge bg-light text-dark border">@car.RegistrationNumber</span></p>
                        <p class="card-text mb-2"><strong>Numer VIN:</strong> <span class="badge bg-light text-dark border">@car.VIN</span></p>

                        <div class="d-flex justify-content-between align-items-center border-top pt-3">
                            <span class="text-success fs-5 fw-bold">
                                @car.PricePerDay zł <small class="text-muted" style="font-size: 11px;">/ doba</small>
                            </span>

                            <button type="button"
                                    class="text-warning bg-transparent border-0 edit-icon fs-5 mx-2"
                                    data-bs-toggle="modal"
                                    data-bs-target="#editCarModal"
                                    data-id="@car.Id"
                                    data-brand="@car.Brand"
                                    data-model="@car.Model"
                                    data-year="@car.ProductionYear"
                                    data-price="@car.PricePerDay"
                                    data-reg="@car.RegistrationNumber"
                                    data-vin="@car.VIN"
                                    data-status="@((int)car.Status)"
                                    data-image="@car.ImageUrl"
                                    title="Edytuj pojazd">
                                ✏️
                            </button>

                            @if (car.Status == CarRental.Models.CarStatus.Available)
                            {
                                <span class="badge bg-success px-3 py-2">Dostępny</span>
                            }
                            else if (car.Status == CarRental.Models.CarStatus.Rented)
                            {
                                <span class="badge bg-danger px-3 py-2">Wynajęty</span>
                            }
                            else
                            {
                                <span class="badge bg-secondary px-3 py-2">W serwisie</span>
                            }
                        </div>
                    </div>
                </div>
            </div>
        }
    }
</div>

<div class="modal fade" id="editCarModal" tabindex="-1" aria-labelledby="editCarModalLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-lg">
        <div class="modal-content border-0 shadow">
            <div class="modal-header bg-warning text-dark">
                <h5 class="modal-title fw-bold" id="editCarModalLabel">✏️ Edycja pojazdu</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body p-4">
                <form method="post" asp-page-handler="Edit" enctype="multipart/form-data">

                    <input type="hidden" asp-for="CarToEdit.Id" id="editCarId" />

                    <div class="row g-3">
                        <div class="col-md-6">
                            <label asp-for="CarToEdit.Brand" class="form-label fw-semibold">Marka</label>
                            <input asp-for="CarToEdit.Brand" id="editCarBrand" class="form-control" required />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CarToEdit.Model" class="form-label fw-semibold">Model</label>
                            <input asp-for="CarToEdit.Model" id="editCarModelField" class="form-control" required />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CarToEdit.ProductionYear" class="form-label fw-semibold">Rok produkcji</label>
                            <input asp-for="CarToEdit.ProductionYear" id="editCarYear" type="number" class="form-control" required />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CarToEdit.PricePerDay" class="form-label fw-semibold">Cena za dobę (zł)</label>
                            <input asp-for="CarToEdit.PricePerDay" id="editCarPrice" type="number" step="0.01" class="form-control" required />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CarToEdit.RegistrationNumber" class="form-label fw-semibold">Numer rejestracyjny</label>
                            <input asp-for="CarToEdit.RegistrationNumber" id="editCarReg" class="form-control" required />
                        </div>

                        <div class="col-md-6">
                            <label asp-for="CarToEdit.VIN" class="form-label fw-semibold">Numer VIN</label>
                            <input asp-for="CarToEdit.VIN" id="editCarVin" class="form-control" required />
                        </div>

                        <div class="col-12">
                            <label asp-for="CarToEdit.Status" class="form-label fw-semibold">Status pojazdu</label>
                            <select asp-for="CarToEdit.Status" id="editCarStatus" class="form-select">
                                <option value="0">Dostępny</option>
                                <option value="1">Wynajęty</option>
                                <option value="2">W serwisie</option>
                            </select>
                        </div>

                        <div class="col-12">
                            <label class="form-label fw-semibold">Zmień zdjęcie pojazdu</label>
                            <input type="hidden" asp-for="CarToEdit.ImageUrl" id="editCarImage" />
                            <input type="file" name="CarImageFile" class="form-control" accept="image/*" />
                            <small class="text-muted text-warning">Wybierz nowy plik tylko jeśli chcesz zastąpić obecne zdjęcie.</small>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 mt-4 pt-3 border-top">
                        <button type="button" class="btn btn-light border" data-bs-dismiss="modal">Anuluj</button>
                        <button type="submit" class="btn btn-warning fw-bold px-4">Zapisz zmiany</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const editCarModal = document.getElementById('editCarModal');
        if (editCarModal) {
            editCarModal.addEventListener('show.bs.modal', function (event) {
                // Przycisk, który wywołał modal
                const button = event.relatedTarget;

                // Pobieranie danych z atrybutów data-*
                const id = button.getAttribute('data-id');
                const brand = button.getAttribute('data-brand');
                const model = button.getAttribute('data-model');
                const year = button.getAttribute('data-year');
                const price = button.getAttribute('data-price');
                const reg = button.getAttribute('data-reg');
                const vin = button.getAttribute('data-vin');
                const status = button.getAttribute('data-status');
                const image = button.getAttribute('data-image');

                // Wstrzykiwanie danych do pól formularza w modalu
                document.getElementById('editCarId').value = id;
                document.getElementById('editCarBrand').value = brand;
                document.getElementById('editCarModelField').value = model;
                document.getElementById('editCarYear').value = year;
                document.getElementById('editCarPrice').value = price.replace(',', '.'); // Kropka dla poprawności inputu typu number
                document.getElementById('editCarReg').value = reg;
                document.getElementById('editCarVin').value = vin;
                document.getElementById('editCarStatus').value = status;
                document.getElementById('editCarImage').value = image;
            });
        }
    </script>
    <partial name="_ValidationScriptsPartial" />
}