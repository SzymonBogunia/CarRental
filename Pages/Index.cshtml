@page
@model IndexModel
@{
    ViewData["Title"] = "Strona główna";
}

<!-- Opcjonalnie: Podpięcie ikon Bootstrapa, jeśli jeszcze ich nie masz w _Layout.cshtml -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">

<div class="container py-5">
    <!-- Hero Section -->
    <div class="text-center mb-5">
        <span class="badge bg-primary-subtle text-primary px-3 py-2 rounded-pill fw-semibold mb-3">System Zarządzania</span>
        <h1 class="display-4 fw-black text-dark mb-3" style="letter-spacing: -1px;">Witaj w <span class="text-primary fw-bold">CarRental</span></h1>
        <p class="lead text-muted mx-auto" style="max-width: 600px;">
            Aplikacja działa prawidłowo. Wybierz jeden z poniższych modułów, aby zarządzać wypożyczalnią samochodów.
        </p>
    </div>

    <!-- Panel Nawigacyjny (Kafelki) -->
    <div class="row g-4 justify-content-center">
        <!-- Kafelek: Flota Pojazdów -->
        <div class="col-md-4 col-sm-6">
            <div class="card h-100 border-0 shadow-sm hover-card transition-all">
                <div class="card-body p-4 text-center d-flex flex-column justify-content-between">
                    <div>
                        <div class="icon-box bg-primary-subtle text-primary rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                            <i class="bi bi-car-front-fill fs-3"></i>
                        </div>
                        <h5 class="card-title fw-bold text-dark mb-2">Flota Pojazdów</h5>
                        <p class="card-text text-muted small">Przeglądaj dostępne samochody, dodawaj nowe pojazdy i zarządzaj ich statusem.</p>
                    </div>
                    <a asp-page="/CarsList" class="btn btn-outline-primary w-100 mt-3 stretched-link">Otwórz flotę</a>
                </div>
            </div>
        </div>

        <!-- Kafelek: Lista Klientów -->
        <div class="col-md-4 col-sm-6">
            <div class="card h-100 border-0 shadow-sm hover-card transition-all">
                <div class="card-body p-4 text-center d-flex flex-column justify-content-between">
                    <div>
                        <div class="icon-box bg-success-subtle text-success rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                            <i class="bi bi-people-fill fs-3"></i>
                        </div>
                        <h5 class="card-title fw-bold text-dark mb-2">Baza Klientów</h5>
                        <p class="card-text text-muted small">Zarządzaj danymi klientów, weryfikuj dokumenty i numery praw jazdy.</p>
                    </div>
                    <!-- Zmieniłem ścieżkę na intuicyjną /CustomersList, popraw jeśli masz inną -->
                    <a asp-page="/CustomersList" class="btn btn-outline-success w-100 mt-3 stretched-link">Pokaż klientów</a>
                </div>
            </div>
        </div>

        <!-- Kafelek: Rezerwacje -->
        <div class="col-md-4 col-sm-6">
            <div class="card h-100 border-0 shadow-sm hover-card transition-all">
                <div class="card-body p-4 text-center d-flex flex-column justify-content-between">
                    <div>
                        <div class="icon-box bg-warning-subtle text-warning rounded-circle mx-auto mb-3 d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                            <i class="bi bi-calendar-check-fill fs-3"></i>
                        </div>
                        <h5 class="card-title fw-bold text-dark mb-2">Rezerwacje</h5>
                        <p class="card-text text-muted small">Twórz nowe rezerwacje, sprawdzaj terminy i rozliczaj aktywne wypożyczenia.</p>
                    </div>
                    <!-- Zmieniłem ścieżkę na intuicyjną /RentalsList lub /Bookings, popraw jeśli masz inną -->
                    <a asp-page="/RentalsList" class="btn btn-outline-warning w-100 mt-3 stretched-link">Zarządzaj</a>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Prosty, subtelny styl dla efektu najechania myszką (możesz wrzucić do pliku site.css) -->
<style>
    .hover-card {
        transition: transform 0.2s ease-in-out, box-shadow 0.2s ease-in-out;
    }

        .hover-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 .5rem 1.5rem rgba(0,0,0,.15) !important;
        }
</style>