@page
@model RentalCreateModel
@{
    ViewData["Title"] = "Nowa Rezerwacja";
}

<div class="row justify-content-center my-5">
    <div class="col-md-8 col-lg-6">
        <div class="card shadow border-0">
            <div class="card-header bg-warning text-dark py-3">
                <h4 class="mb-0 fw-bold">📅 Tworzenie Nowej Rezerwacji</h4>
            </div>
            <div class="card-body p-4">
                <form method="post">

                    <div asp-validation-summary="ModelOnly" class="alert alert-danger mb-3 py-2" role="alert"></div>

                    <div class="mb-3">
                        <label asp-for="NewRental.CarId" class="form-label fw-semibold">🚗 Wybierz samochód</label>
                        <select asp-for="NewRental.CarId" id="carSelect" asp-items="Model.CarOptions" class="form-select" required>
                            <option value="">-- Wybierz pojazd z floty --</option>
                        </select>
                        <span asp-validation-for="NewRental.CarId" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="NewRental.CustomerId" class="form-label fw-semibold">👤 Wybierz klienta</label>
                        <select asp-for="NewRental.CustomerId" asp-items="Model.CustomerOptions" class="form-select" required>
                            <option value="">-- Wybierz kierowcę z bazy --</option>
                        </select>
                        <span asp-validation-for="NewRental.CustomerId" class="text-danger small"></span>
                    </div>

                    <div class="row g-3 mb-4">
                        <div class="col-md-6">
                            <label asp-for="NewRental.StartDate" class="form-label fw-semibold">📅 Data rozpoczęcia</label>
                            <input asp-for="NewRental.StartDate" asp-format="{0:yyyy-MM-ddTHH:00}" type="datetime-local" class="form-control" required />
                            <span asp-validation-for="NewRental.StartDate" class="text-danger small"></span>
                        </div>

                        <div class="col-md-6">
                            <label asp-for="NewRental.EndDate" class="form-label fw-semibold">🏳️ Data zakończenia</label>
                            <input asp-for="NewRental.EndDate" asp-format="{0:yyyy-MM-ddTHH:00}" type="datetime-local" class="form-control" required />
                            <span asp-validation-for="NewRental.EndDate" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="card bg-light border-0 p-3 mb-4 shadow-sm">
                        <div class="d-flex justify-content-between align-items-center">
                            <div>
                                <h6 class="mb-0 text-muted fw-bold text-uppercase" style="font-size: 0.8rem;">Szacowany koszt wynajmu</h6>
                                <small id="durationBadge" class="text-secondary fw-semibold">Wybierz daty i auto...</small>
                            </div>
                            <div>
                                <span id="livePriceDisplay" class="fs-3 fw-bold text-dark">0.00</span> <span class="fw-bold text-dark">zł</span>
                            </div>
                        </div>
                    </div>

                    <div class="d-flex justify-content-end gap-2 pt-3 border-top">
                        <a asp-page="/RentalsList" class="btn btn-light border">Anuluj</a>
                        <button type="submit" class="btn btn-warning fw-bold px-4 text-dark">Zatwierdź wynajem</button>
                    </div>

                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // próba pobrania po ID, a jeśli nie ma - szukamy po atrybucie name nadawanym przez ASP.NET
            const carSelect = document.getElementById("carSelect") || document.querySelector("[name='NewRental.CarId']");
            const startDateInput = document.getElementById("startDateInput") || document.querySelector("[name='NewRental.StartDate']");
            const endDateInput = document.getElementById("endDateInput") || document.querySelector("[name='NewRental.EndDate']");

            const livePriceDisplay = document.getElementById("livePriceDisplay");
            const durationBadge = document.getElementById("durationBadge");


            function calculateLivePrice() {
                if (!carSelect || !startDateInput || !endDateInput) {
                    durationBadge.textContent = "⚠️ Błąd skryptu: Nie znaleziono pól formularza.";
                    return;
                }

                const selectedOption = carSelect.options[carSelect.selectedIndex];
                if (!selectedOption || selectedOption.value === "") {
                    livePriceDisplay.textContent = "0.00";
                    durationBadge.textContent = "Wybierz samochód...";
                    return;
                }

                // Pobieramy tekst opcji
                const optionText = selectedOption.text;

                // Szukamy ceny 
                const priceMatch = optionText.match(/([\d,.]+)\s*zł\/dobę/);

                if (!priceMatch) {
                    livePriceDisplay.textContent = "0.00";
                    durationBadge.textContent = "Nie znaleziono ceny dla tego auta.";
                    return;
                }

                const pricePerDay = parseFloat(priceMatch[1].replace(',', '.'));
                const startVal = startDateInput.value;
                const endVal = endDateInput.value;

                // Jeśli daty są jeszcze niewypełnione
                if (!startVal || !endVal) {
                    livePriceDisplay.textContent = "0.00";
                    durationBadge.textContent = "Uzupełnij daty rezerwacji...";
                    return;
                }

                const startDate = new Date(startVal);
                const endDate = new Date(endVal);

                // Sprawdzanie chronologii
                if (endDate <= startDate) {
                    livePriceDisplay.textContent = "0.00";
                    durationBadge.textContent = "⚠️ Data zwrotu musi być późniejsza niż startu!";
                    durationBadge.classList.add("text-danger");
                    return;
                }
                durationBadge.classList.remove("text-danger");

                // Obliczanie różnicy czasu i zaokrąglanie w górę
                const differenceInTime = endDate.getTime() - startDate.getTime();
                const differenceInDays = Math.ceil(differenceInTime / (1000 * 3600 * 24));
                const finalDays = differenceInDays <= 0 ? 1 : differenceInDays;

                const totalPrice = finalDays * pricePerDay;

                // Wyświetlanie sformatowanej ceny
                livePriceDisplay.textContent = totalPrice.toFixed(2);
                durationBadge.textContent = `Czas trwania: ${finalDays} ${finalDays === 1 ? 'doba' : 'dni'} (x ${pricePerDay.toFixed(2)} zł)`;
            }

            // Podpięcie zdarzeń pod wykryte elementy
            if (carSelect) carSelect.addEventListener("change", calculateLivePrice);
            if (startDateInput) startDateInput.addEventListener("change", calculateLivePrice);
            if (endDateInput) endDateInput.addEventListener("change", calculateLivePrice);

            // Wywołanie startowe
            calculateLivePrice();
        });
    </script>
    <partial name="_ValidationScriptsPartial" />
}